# ==================== Harbor 镜像仓库配置 ====================
HARBOR_REGISTRY=192.168.163.135
HARBOR_NAMESPACE=library
HARBOR_REGISTRY_USER=your-username
HARBOR_REGISTRY_PASSWD=your-password

# ==================== 镜像名称配置 ====================
IMAGE_GATEWAY=yudao_gateway
IMAGE_SYSTEM=yudao_system
IMAGE_INFRA=yudao_infra
IMAGE_WEB=yudao_ui_admin

# ==================== 镜像版本配置 ====================
# 开发环境使用 latest，生产环境使用具体版本号
VERSION=latest
IMAGE_TAG_LATEST=latest

# ==================== Ingress 域名配置 ====================
INGRESS_API_HOST=api.yudao.com
INGRESS_WEB_HOST=www.yudao.com

# ==================== MetalLB IP 池配置 ====================
METALLB_POOL_START=192.168.206.200
METALLB_POOL_END=192.168.206.220

# ==================== 应用配置 ====================
# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# Nacos 配置
NACOS_ADDR=nacos:8848
NACOS_NAMESPACE=

# MySQL 配置
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=ry-cloud
MYSQL_PASSWORD=change-me-in-production

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=1
REDIS_PASSWORD=change-me-in-production

# ==================== GitLab CI/CD 配置 ====================
# GitLab Runner 需要配置这些变量
# CI_REGISTRY_USER=${HARBOR_REGISTRY_USER}
# CI_REGISTRY_PASSWORD=${HARBOR_REGISTRY_PASSWD}
# CI_COMMIT_SHORT_SHA=$(git rev-parse --short HEAD)

# ==================== K8s 配置 ====================
# 命名空间
K8S_NAMESPACE_DEFAULT=default
K8S_NAMESPACE_DEV=dev
K8S_NAMESPACE_PROD=production

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
